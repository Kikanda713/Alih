# Frontend (Vite) environment — copy to .env.local and fill in.
# All client-exposed vars MUST be prefixed with VITE_.

# Auth0 SPA application (Applications → your SPA app in the Auth0 dashboard)
VITE_AUTH0_DOMAIN=dev-dyrk0b3w16k8cfek.us.auth0.com
VITE_AUTH0_CLIENT_ID=XYyXW8EOCEXIaVQStJl6S7cHpgsT4SNf

# Auth0 API Audience (Applications → APIs → Identifier). Required so Auth0 issues
# an access token (JWT) the backend can validate. Should match the gateway's
# AUTH0_AUDIENCE.
VITE_AUTH0_AUDIENCE=https://api.tindisa.com

# Tindisa API gateway (BFF) base URL.
#   LOCAL : http://localhost:3000
#   PROD  : https://api.tindisa.com
VITE_API_URL=http://localhost:3000

# Callback / logout Auth0 (convention Wanzo : chemin /auth/callback).
# OPTIONNEL : laissés vides, ils valent window.location.origin + '/auth/callback'
# (callback) et window.location.origin (logout → landing). Renseigner uniquement
# pour forcer une valeur. Déclarer ces URLs dans l'app SPA Auth0 :
#   Callback : http://localhost:5173/auth/callback , https://tindisa.com/auth/callback
#   Logout / Web Origins : http://localhost:5173 , https://tindisa.com (+ www)
# VITE_AUTH0_CALLBACK_URL=
# VITE_AUTH0_LOGOUT_URL=

# Cloudinary — upload des images produit (preset NON SIGNÉ requis).
# Dashboard Cloudinary → Settings → Upload → Upload presets (Signing mode: Unsigned).
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Canaux du marchand (accès direct depuis le dashboard). Valeurs par défaut :
# WhatsApp Web / Telegram Web / Facebook. La page Facebook peut être propre au marchand.
VITE_WHATSAPP_URL=https://web.whatsapp.com
VITE_TELEGRAM_URL=https://web.telegram.org
VITE_FACEBOOK_PAGE_URL=https://www.facebook.com

# MODE DÉMO (à retirer en production) — données fictives, sans Auth0 ni backend.
# Auto-activé si Auth0 n'est pas configuré. Forcer avec true / désactiver avec false.
VITE_DEMO_MODE=true
